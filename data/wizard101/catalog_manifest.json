        "id",
        "name",
        "source",
        "verification",
        "category",
        "formula",
        "applies_to"
      ]
    },
    "pip_system": {
      "path": "data/wizard101/pip_system.jsonl",
      "required_fields": [
        "id",
        "name",
        "source",
        "verification",
        "rules",
        "formula"
      ]
    },
    "worlds": {
      "path": "data/wizard101/worlds.jsonl",
      "required_fields": [
        "id",
        "name",
        "source",
        "verification",
        "zones"
      ]
    },
    "npcs": {
