      "required_fields": [
        "id",
        "name",
        "source",
        "verification",
        "stats",
        "sources"
      ]
    },
    "jewels": {
      "path": "data/wizard101/jewels.jsonl",
      "required_fields": [
        "id",
        "name",
        "source",
        "verification",
        "jewel_type",
        "level_band",
        "stats",
        "sources"
      ]
    },
    "reagents": {
