{
  "schema_version": "wizard101-knowledge-v1",
  "description": "Manifest for verified Wizard101 knowledge used by Deimos/WizCare automation. The catalog is intentionally fact-first: unknown data must stay absent instead of being guessed, and completion requires comprehensive gear, enemy, spell, stat, pip, quest, world, NPC, pet, mount, jewel, reagent, and source coverage.",
  "datasets": {
    "enemies": {
      "path": "data/wizard101/enemies.jsonl",
      "required_fields": [
        "id",
        "name",
        "source",
        "verification",
        "combat",
        "locations",
        "drops"
      ]
    },
    "gear": {
      "path": "data/wizard101/gear.jsonl",
      "required_fields": [
        "id",
        "name",
        "source",
        "verification",
        "item_type",
        "equip_slot",
        "requirements",
        "stats",
        "sockets",
        "sources"
      ]
    },
    "spells": {
      "path": "data/wizard101/spells.jsonl",
      "required_fields": [
        "id",
        "name",
        "source",
        "verification",
        "school",
        "requirements",
        "pip_cost",
        "effects",
        "acquisition"
      ]
    },
    "quests": {
      "path": "data/wizard101/quests.jsonl",
      "required_fields": [
        "id",
        "name",
        "source",
        "verification",
        "world",
        "quest_line",
        "requirements",
        "steps",
        "rewards"
      ]
    },
    "stats": {
